{
  "manifest_version": 3,
  "name": "OneClick Video Downloader",
  "description": "Download videos from YouTube, Instagram, TikTok, Douyin and more.",
  "version": "0.1.0",

  "action": {
    "default_title": "OneClick Video Downloader",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging",
    "storage",
    "webRequest"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}
