{
  "manifest_version": 3,
  "name": "OneClick Downloader",
  "description": "Download videos from YouTube, Instagram, TikTok and more.",
  "version": "0.1.0",

  "action": {
    "default_title": "OneClick Downloader",
    "default_popup": "popup.html"
  },

  "permissions": [

    "activeTab",

    "tabs"

  ],

  "host_permissions": [

    "http://127.0.0.1:8765/*"

  ]
}